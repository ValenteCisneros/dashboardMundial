{
  "name": "kiosko-dashboard",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.0",
    "prisma": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "recharts": "^2.13.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "scripts": {
    "start": "PORT=3001 react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "db:generate": "prisma generate --schema=server/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=server/prisma/schema.prisma",
    "db:seed": "node server/prisma/seed.js",
    "db:studio": "prisma studio --schema=server/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "server/prisma/schema.prisma",
    "seed": "node server/prisma/seed.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
