// Prisma schema for Kiosk Dashboard
// PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Visitor {
  id             String    @id @default(cuid())
  nationalityCode String?   @map("nationality_code")
  createdAt      DateTime  @default(now()) @map("created_at")
  sessions       Session[]

  @@map("visitors")
}

model Session {
  id          String   @id @default(cuid())
  visitorId   String?  @map("visitor_id")
  visitor     Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  startedAt   DateTime @map("started_at")
  endedAt     DateTime? @map("ended_at")
  durationMin Int?     @map("duration_min")
  events      Event[]
  contentViews ContentView[]
  adImpressions AdImpression[]
  leads       Lead[]

  @@map("sessions")
}

model Event {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String   // detected, qr_scan, qr_submit, game_start, game_end, content_view, etc.
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  @@map("events")
}

model ContentView {
  id             String   @id @default(cuid())
  sessionId      String   @map("session_id")
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  category       String
  timeSpentMin   Float?   @map("time_spent_min")
  saved          Boolean  @default(false)
  shared         Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("content_views")
}

model Advertiser {
  id     String  @id @default(cuid())
  name   String
  ads    Ad[]
  places Place[]

  @@map("advertisers")
}

model Place {
  id           String       @id @default(cuid())
  name         String
  latitude     Float         @map("latitude")
  longitude    Float         @map("longitude")
  category     String
  description  String?      @db.Text
  imageUrl     String?      @map("image_url")
  advertiserId String?       @map("advertiser_id")
  advertiser   Advertiser?  @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("places")
}

model Ad {
  id           String   @id @default(cuid())
  advertiserId String   @map("advertiser_id")
  advertiser   Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  name         String
  impressions  AdImpression[]

  @@map("ads")
}

model AdImpression {
  id          String   @id @default(cuid())
  adId        String   @map("ad_id")
  ad          Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  sessionId   String?  @map("session_id")
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  placement   String?  // turismo_hero, turismo_sidebar, world_cup_leaderboard, etc.
  durationSec Int?     @map("duration_sec")
  shownAt     DateTime @default(now()) @map("shown_at")
  clicked     Boolean  @default(false)

  @@map("ad_impressions")
}

model Match {
  id        String   @id @default(cuid())
  homeTeam  String   @map("home_team")
  awayTeam  String   @map("away_team")
  venue     String
  matchDate DateTime @map("match_date")
  phase     String   // group, round_16, quarter, semi, final
  homeScore Int?     @map("home_score")
  awayScore Int?     @map("away_score")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("matches")
}

model Lead {
  id                 String   @id @default(cuid())
  sessionId          String?  @map("session_id")
  session            Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  source             String?  // qr, game, turismo_monterrey, etc.
  email              String?
  firstName          String?  @map("first_name")
  lastName           String?  @map("last_name")
  phone              String?
  consentNewsletter  Boolean  @default(false) @map("consent_newsletter")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("leads")
}
