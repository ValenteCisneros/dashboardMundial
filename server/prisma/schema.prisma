generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Visitor {
  id              String    @id @default(cuid())
  nationalityCode String?   @map("nationality_code")
  createdAt       DateTime  @default(now()) @map("created_at")
  sessions        Session[]

  @@map("visitors")
}

model Session {
  id            String         @id @default(cuid())
  visitorId     String?        @map("visitor_id")
  startedAt     DateTime       @map("started_at")
  endedAt       DateTime?      @map("ended_at")
  durationMin   Int?           @map("duration_min")
  adImpressions AdImpression[]
  contentViews  ContentView[]
  events        Event[]
  leads         Lead[]
  visitor       Visitor?       @relation(fields: [visitorId], references: [id])

  @@map("sessions")
}

model Event {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  type      String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("events")
}

model ContentView {
  id           String   @id @default(cuid())
  sessionId    String   @map("session_id")
  category     String
  timeSpentMin Float?   @map("time_spent_min")
  saved        Boolean  @default(false)
  shared       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("content_views")
}

model Advertiser {
  id     String  @id @default(cuid())
  name   String
  ads    Ad[]
  places Place[]

  @@map("advertisers")
}

model Place {
  id           String       @id @default(cuid())
  name         String
  latitude     Float         @map("latitude")
  longitude    Float         @map("longitude")
  category     String
  description  String?      @db.Text
  imageUrl     String?      @map("image_url")
  advertiserId String?       @map("advertiser_id")
  advertiser   Advertiser?  @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("places")
}

model Ad {
  id           String         @id @default(cuid())
  advertiserId String         @map("advertiser_id")
  name         String
  impressions  AdImpression[]
  advertiser   Advertiser     @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@map("ads")
}

model AdImpression {
  id          String   @id @default(cuid())
  adId        String   @map("ad_id")
  sessionId   String?  @map("session_id")
  durationSec Int?     @map("duration_sec")
  shownAt     DateTime @default(now()) @map("shown_at")
  clicked     Boolean  @default(false)
  ad          Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  session     Session? @relation(fields: [sessionId], references: [id])

  @@map("ad_impressions")
}

model Match {
  id        String   @id @default(cuid())
  sessionId String?  @map("session_id")
  source    String?
  createdAt DateTime @default(now()) @map("created_at")
  session   Session? @relation(fields: [sessionId], references: [id])

  @@map("matches")
}

model Lead {
  id                 String   @id @default(cuid())
  sessionId          String?  @map("session_id")
  session            Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  source             String?  // qr, game, turismo_monterrey, etc.
  email              String?
  firstName          String?  @map("first_name")
  lastName           String?  @map("last_name")
  phone              String?
  consentNewsletter  Boolean  @default(false) @map("consent_newsletter")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("leads")
}
